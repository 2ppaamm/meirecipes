WORDPRESS_URL=https://www.meirecipes.com
SITE_URL=https://meirecipes.com
WP_REVALIDATE_SECONDS=600

# Generate: openssl rand -hex 32
REVALIDATE_SECRET=

# ─── Video URLs (optional) ─────────────────────────────────────
# Set these to surface videos on their respective pages before the
# corresponding WordPress posts exist. Once a real post is published
# with the matching slug, its meta video_url takes priority.
#
# Supported: YouTube watch / shorts / youtu.be, Vimeo.

# The Mei Wok page (/the-wok)
MEI_WOK_VIDEO_URL=

# Feature: How to make curry puffs in a hotel room (/features/curry-puffs-hotel-room)
MEI_FEATURE_VIDEO_CURRY_PUFFS_HOTEL_ROOM=

# Recipe: butter prawns
# Set via the WordPress editorial metabox on the /r/butter-prawns post —
# no env var needed for recipe video embeds.
